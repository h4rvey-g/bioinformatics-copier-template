[workspace]
name = "{{ project_slug }}"
description = "{{ description }}"
authors = [{% if author_email %}"{{ author_name }} <{{ author_email }}>"{% else %}"{{ author_name }}"{% endif %}]
channels = ["conda-forge", "bioconda"]
channel-priority = "strict"
platforms = [{% for platform in pixi_platforms %}"{{ platform }}"{% if not loop.last %}, {% endif %}{% endfor %}]
requires-pixi = ">=0.46.0"

[dependencies]
nextflow = "*"
git = "*"

[tasks]
run = "nextflow run . -profile {{ 'slurm' if has_slurm else 'local' }}"
config = "nextflow config . -profile {{ 'slurm' if has_slurm else 'local' }} -flat"
lint = "nextflow lint ."
clean = "rm -rf work .nextflow .nextflow*"
